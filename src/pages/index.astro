---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const featuredPost = posts[0];
const restPosts = posts.slice(1, 10);
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="mx-auto max-w-3xl px-4 py-12 sm:py-20">
			<!-- Cinematic Intro -->
			<section class="mb-16">
				<h1 class="hero-gradient text-3xl sm:text-4xl font-extrabold tracking-tight mb-4 text-transparent bg-clip-text bg-gradient-to-br from-gray-900 via-gray-600 to-gray-900 dark:from-white dark:via-gray-400 dark:to-white">
					건설 현장에 AI를 입히다
				</h1>
				<p class="text-[16px] sm:text-[17px] text-[--color-ink-light] dark:text-[--color-dark-ink-light] leading-relaxed max-w-[90%] font-medium">
					건설 엔지니어가 <span class="text-[--color-ink] dark:text-[--color-dark-ink] font-semibold">AI</span>와 <span class="text-[--color-ink] dark:text-[--color-dark-ink] font-semibold">바이브코딩</span>으로 현장의 불합리한 문제를 해결하는 기록입니다.
				</p>
				<!-- Scroll indicator -->
				<div class="mt-8 flex justify-center">
					<svg class="scroll-indicator w-5 h-5 text-[--color-ink-faint] dark:text-[--color-dark-ink-faint]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
						<path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7" />
					</svg>
				</div>
			</section>

			<!-- Featured Post -->
			{featuredPost && (
				<section class="mb-12">
					<div class="flex items-center justify-between mb-4 px-1">
						<h2 class="text-sm font-semibold tracking-wide uppercase text-[--color-accent] dark:text-[--color-dark-accent]">Featured</h2>
					</div>
					<a href={`/blog/${featuredPost.id}/`} class="post-item post-featured group block no-underline p-6 rounded-2xl transition-all duration-300 hover:bg-[--color-surface-alt] dark:hover:bg-[--color-dark-surface-alt] hover:shadow-sm border border-[--color-border] dark:border-[--color-dark-border]">
						<h3 class="text-[19px] sm:text-[21px] font-bold text-[--color-ink] group-hover:text-[--color-link] dark:text-[--color-dark-ink] dark:group-hover:text-[--color-dark-link] tracking-tight mb-2 transition-colors">
							{featuredPost.data.title}
						</h3>
						<p class="text-[14px] sm:text-[15px] text-[--color-ink-muted] dark:text-[--color-dark-ink-muted] leading-relaxed line-clamp-2 mb-3">
							{featuredPost.data.description}
						</p>
						<div class="text-[13px] font-mono text-[--color-ink-faint] dark:text-[--color-dark-ink-faint] flex items-center gap-2">
							<FormattedDate date={featuredPost.data.pubDate} />
							{featuredPost.data.tags && featuredPost.data.tags.length > 0 && (
								<>
									<span class="opacity-50">&middot;</span>
									<span class="truncate">{featuredPost.data.tags[0]}</span>
								</>
							)}
						</div>
					</a>
				</section>
			)}

			<!-- Recent Posts -->
			<section>
				<div class="flex items-center justify-between mb-6 px-1">
					<h2 class="text-sm font-semibold tracking-wide uppercase text-[--color-ink-muted] dark:text-[--color-dark-ink-muted]">Latest Logs</h2>
					<a href="/blog" class="text-xs font-medium text-[--color-ink-faint] hover:text-[--color-ink] dark:text-[--color-dark-ink-faint] dark:hover:text-[--color-dark-ink] transition-colors no-underline">
						View All →
					</a>
				</div>
				<ul class="divide-y divide-[--color-border] dark:divide-[--color-dark-border] divide-opacity-50">
					{restPosts.map((post) => (
						<li>
							<a href={`/blog/${post.id}/`} class="post-item group block no-underline py-5 rounded-lg transition-all duration-300 hover:bg-[--color-surface-alt] dark:hover:bg-[--color-dark-surface-alt]">
								<h3 class="text-[17px] font-bold text-[--color-ink] group-hover:text-[--color-link] dark:text-[--color-dark-ink] dark:group-hover:text-[--color-dark-link] tracking-tight mb-1 transition-colors">
									{post.data.title}
								</h3>
								<p class="text-[14px] text-[--color-ink-muted] dark:text-[--color-dark-ink-muted] leading-relaxed line-clamp-2 mb-3">
									{post.data.description}
								</p>
								<div class="text-[13px] font-mono text-[--color-ink-faint] dark:text-[--color-dark-ink-faint] flex items-center gap-2">
									<FormattedDate date={post.data.pubDate} />
									{post.data.tags && post.data.tags.length > 0 && (
										<>
											<span class="opacity-50">&middot;</span>
											<span class="truncate">{post.data.tags[0]}</span>
										</>
									)}
								</div>
							</a>
						</li>
					))}
				</ul>
			</section>
		</main>
		<div class="border-t border-[--color-border] dark:border-[--color-dark-border]">
			<Footer />
		</div>
	</body>
</html>
