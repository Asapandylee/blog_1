---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const allTags = [...new Set(posts.flatMap(post => post.data.tags))];
const visibleTagCount = 6;
const mainTags = allTags.slice(0, visibleTagCount);
const moreTags = allTags.slice(visibleTagCount);
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={`블로그 | ${SITE_TITLE}`} description="건설산업, AI, 바이브코딩에 대한 글 모음" />
	</head>
	<body>
		<Header />
		<main class="mx-auto max-w-3xl px-4 py-12 sm:py-20">
			<h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight mb-3">Logs</h1>
			<p class="text-[15px] text-[--color-ink-muted] dark:text-[--color-dark-ink-muted] mb-10 leading-relaxed">건설 산업, AI 기술, 그리고 바이브코딩에 관한 잡다한 기록들입니다.</p>

			<!-- Tags -->
			{allTags.length > 0 && (
				<div class="mb-10 flex flex-wrap gap-2" id="tags-container">
					<button data-tag="all" class="tag-filter active text-[12px] font-medium px-3 py-1.5 rounded-full border border-[--color-link] text-[--color-surface] bg-[--color-link] dark:border-[--color-dark-link] dark:text-[--color-dark-surface] dark:bg-[--color-dark-link] transition-all">All</button>
					{mainTags.map(tag => (
						<button data-tag={tag} class="tag-filter text-[12px] font-medium px-3 py-1.5 rounded-full border border-[--color-border] text-[--color-ink-muted] hover:border-[--color-link] hover:text-[--color-link] dark:border-[--color-dark-border] dark:text-[--color-dark-ink-muted] dark:hover:border-[--color-dark-link] dark:hover:text-[--color-dark-link] transition-all bg-transparent">{tag}</button>
					))}
					{moreTags.length > 0 && (
						<button id="tags-toggle" class="text-[12px] font-medium px-3 py-1.5 rounded-full border border-dashed border-[--color-border] text-[--color-ink-faint] hover:border-[--color-ink-muted] hover:text-[--color-ink-muted] dark:border-[--color-dark-border] dark:text-[--color-dark-ink-faint] dark:hover:border-[--color-dark-ink-muted] dark:hover:text-[--color-dark-ink-muted] transition-all bg-transparent">
							+{moreTags.length} more
						</button>
					)}
					{moreTags.map(tag => (
						<button data-tag={tag} class="tag-filter hidden-tag hidden text-[12px] font-medium px-3 py-1.5 rounded-full border border-[--color-border] text-[--color-ink-muted] hover:border-[--color-link] hover:text-[--color-link] dark:border-[--color-dark-border] dark:text-[--color-dark-ink-muted] dark:hover:border-[--color-dark-link] dark:hover:text-[--color-dark-link] transition-all bg-transparent">{tag}</button>
					))}
				</div>
			)}

			<!-- Posts -->
			<ul class="divide-y divide-[--color-border] dark:divide-[--color-dark-border] divide-opacity-50" id="posts-list">
				{posts.map((post) => (
					<li data-tags={JSON.stringify(post.data.tags)}>
						<a href={`/blog/${post.id}/`} class="post-item group block no-underline py-5 rounded-lg transition-all duration-300 hover:bg-[--color-surface-alt] dark:hover:bg-[--color-dark-surface-alt]">
							<h3 class="text-[17px] font-bold text-[--color-ink] group-hover:text-[--color-link] dark:text-[--color-dark-ink] dark:group-hover:text-[--color-dark-link] tracking-tight mb-1 transition-colors">
								{post.data.title}
							</h3>
							<p class="text-[14px] text-[--color-ink-muted] dark:text-[--color-dark-ink-muted] leading-relaxed line-clamp-2 mb-3">
								{post.data.description}
							</p>
							<div class="text-[13px] font-mono text-[--color-ink-faint] dark:text-[--color-dark-ink-faint] flex items-center gap-2">
								<FormattedDate date={post.data.pubDate} />
								{post.data.tags && post.data.tags.length > 0 && (
									<>
										<span class="opacity-50">&middot;</span>
										<span class="truncate">{post.data.tags[0]}</span>
									</>
								)}
							</div>
						</a>
					</li>
				))}
			</ul>
		</main>
		<Footer />
	</body>
</html>

<script>
	// Tag filter logic
	const tagButtons = document.querySelectorAll('.tag-filter');
	const postItems = document.querySelectorAll('#posts-list > li');

	tagButtons.forEach(btn => {
		btn.addEventListener('click', () => {
			const tag = btn.getAttribute('data-tag');

			tagButtons.forEach(b => {
				b.classList.remove('border-[--color-link]', 'text-[--color-surface]', 'bg-[--color-link]', 'dark:border-[--color-dark-link]', 'dark:text-[--color-dark-surface]', 'dark:bg-[--color-dark-link]');
				b.classList.add('border-[--color-border]', 'text-[--color-ink-muted]', 'bg-transparent', 'dark:border-[--color-dark-border]', 'dark:text-[--color-dark-ink-muted]');
			});
			btn.classList.remove('border-[--color-border]', 'text-[--color-ink-muted]', 'bg-transparent', 'dark:border-[--color-dark-border]', 'dark:text-[--color-dark-ink-muted]');
			btn.classList.add('border-[--color-link]', 'text-[--color-surface]', 'bg-[--color-link]', 'dark:border-[--color-dark-link]', 'dark:text-[--color-dark-surface]', 'dark:bg-[--color-dark-link]');

			postItems.forEach(item => {
				if (tag === 'all') {
					(item as HTMLElement).style.display = '';
				} else {
					const tags = JSON.parse(item.getAttribute('data-tags') || '[]');
					(item as HTMLElement).style.display = tags.includes(tag) ? '' : 'none';
				}
			});
		});
	});

	// Tags toggle logic
	const tagsToggle = document.getElementById('tags-toggle');
	if (tagsToggle) {
		let expanded = false;
		tagsToggle.addEventListener('click', () => {
			expanded = !expanded;
			const hiddenTags = document.querySelectorAll('.hidden-tag');
			hiddenTags.forEach(tag => {
				tag.classList.toggle('hidden', !expanded);
			});
			tagsToggle.textContent = expanded ? 'less' : `+${hiddenTags.length} more`;
		});
	}
</script>
