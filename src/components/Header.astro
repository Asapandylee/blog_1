---
import { SITE_TITLE } from '../consts';

const currentPath = Astro.url.pathname;

const navLinks = [
	{ href: '/blog', label: '블로그' },
	{ href: '/about', label: '소개' },
];
---

<header class="sticky top-0 z-50 w-full backdrop-blur-lg bg-[--color-surface]/80 dark:bg-[--color-dark-surface]/80 border-b border-[--color-border] dark:border-[--color-dark-border]">
	<div class="mx-auto max-w-3xl px-4 py-4 flex items-center justify-between transition-colors duration-300">
		<a href="/" class="text-[17px] font-bold tracking-tight text-[--color-ink] no-underline hover:opacity-80 transition-opacity dark:text-[--color-dark-ink]">
			{SITE_TITLE}
		</a>
		<div class="flex items-center gap-4">
			{navLinks.map(link => (
				<a
					href={link.href}
					class:list={[
						'text-sm no-underline transition-colors',
						currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
							? 'text-[--color-ink] font-medium dark:text-[--color-dark-ink]'
							: 'text-[--color-ink-muted] hover:text-[--color-ink] dark:text-[--color-dark-ink-muted] dark:hover:text-[--color-dark-ink]'
					]}
				>
					{link.label}
				</a>
			))}
			<button
				id="theme-toggle"
				type="button"
				class="text-[--color-ink-faint] hover:text-[--color-ink] dark:text-[--color-dark-ink-faint] dark:hover:text-[--color-dark-ink] transition-colors"
				aria-label="다크모드 토글"
			>
				<svg class="hidden h-4 w-4 dark:block" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
					<path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" />
				</svg>
				<svg class="block h-4 w-4 dark:hidden" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
					<path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" />
				</svg>
			</button>
		</div>
	</div>
</header>
<script>
	const toggle = document.getElementById('theme-toggle');
	toggle?.addEventListener('click', () => {
		const isDark = document.documentElement.classList.toggle('dark');
		localStorage.setItem('theme', isDark ? 'dark' : 'light');
	});
</script>
